{
  "enabledPlugins": {
    "avila-tek-skill-pack@avila-tek": true
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {
        "MAX_MCP_OUTPUT_TOKENS": "25000"
      }
    },
    "shadcn": {
      "command": "npx",
      "args": ["-y", "@krazor/shadcn-mcp@latest"],
      "env": {
        "MAX_MCP_OUTPUT_TOKENS": "25000"
      }
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch@latest"],
      "env": {
        "MAX_MCP_OUTPUT_TOKENS": "25000"
      }
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-mcp@latest"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}",
        "MAX_MCP_OUTPUT_TOKENS": "25000"
      }
    },
    "postman": {
      "command": "npx",
      "args": ["-y", "@postman/postman-mcp-server@latest"],
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}",
        "MAX_MCP_OUTPUT_TOKENS": "25000"
      }
    },
    "chrome": {
      "command": "npx",
      "args": ["-y", "chrome-mcp@latest"],
      "env": {
        "MAX_MCP_OUTPUT_TOKENS": "25000"
      }
    }
  }
}
